# Source of truth for google-search-ranking API (use this file — not only .env.example).
# Server
PORT=5524   

# Screenshot capture mode
# true  = headless (live/cloud server — stealth mode, no visible window)
# false = headed  (local dev machine — Chrome window opens for CAPTCHA solving)
# Leave unset to auto-detect: Windows/macOS → headed, Linux server → headless
CAPTURE_HEADLESS=true

# PRO TIP: Add a residential proxy here for 100% stability on live servers!
# PLAYWRIGHT_PROXY=http://user:pass@host:port
# Residential proxy for real Google screenshots on live server (bypasses CAPTCHA)
# Free proxies: sign up at https://webshare.io → get 10 free residential proxies
# Format:  PLAYWRIGHT_PROXY=http://username:password@proxy-host:port
PLAYWRIGHT_PROXY=http://hruvppmj:oxc8umbj07hb@31.59.20.176:6754

# SerpAPI (DISABLED to prevent fake screenshot fallbacks)
# SERPAPI_API_KEY=df60335aa133fafec66fb5d3d182d77b1cf38a242cc8a02f199631cfebe09885

# DataForSEO — Local Finder → rank → check_url → Scrapfly screenshot (POST /capture-screenshot with useDataForSeo: true)
DATAFORSEO_LOGIN=gahan@synoventum.us.cc
DATAFORSEO_PASSWORD=2ce3afb510776a8b
DATAFORSEO_TIMEOUT_MS=30000
DATAFORSEO_RETRY_COUNT=3
# /api/ranking/automated-run rank source: dataforseo = Local Finder JSON (explicit — overrides parent repo .env if any)
AUTOMATED_RANK_ENGINE=dataforseo

# Scrapfly Cloud Browser API key. Empty => local Playwright + PLAYWRIGHT_PROXY only.
SCRAPFLY_API_KEY=scp-live-35bcc05e488b470aa974e8debd52a6a8
SCRAPFLY_PROXY_POOL=residential
SCRAPFLY_PROXY_COUNTRY=us
SCRAPFLY_PROXY_COUNTRY_FALLBACKS=de,gb
# udm=1: capture must use googleSearchUrl from automated-run (set false only if you rebuild URL)
ZENROWS_STRICT_UDM1_URL=true
# After CDP single goto, wait ms so Places list paints before screenshot (1000–15000)
ZENROWS_UDM1_SETTLE_MS=5000
# Screenshot stability: 80s timeout + retry on transient cloud/proxy issues
CAPTURE_GOTO_TIMEOUT_MS=80000
CAPTURE_PAGE_READY_MS=80000
ZENROWS_UDM1_CAPTURE_BUDGET_MS=80000
ZENROWS_UDM1_CAPTURE_BUDGET_PER_ATTEMPT_MS=80000
ZENROWS_UDM1_RETRY_PER_LOCATION=2
ZENROWS_UDM1_RETRY_BACKOFF_MS=1500
CAPTURE_EDGE_TIMEOUT_MS=120000
SCREENSHOT_CAPTURE_CONCURRENCY=3
# Keep screenshot viewport stable and readable (same normal zoom every run)
CAPTURE_VIEWPORT_WIDTH=1366
CAPTURE_VIEWPORT_HEIGHT=768
# Optional: run udm=1 screenshot inside every automated-run without client flag (dashboard already sends captureScreenshotImmediately: true).
# AUTO_UDM1_SCREENSHOT_AFTER_RANK=false
PLAYWRIGHT_CAPTURE_NO_PROXY=true

# udm=1 capture — use this file as source of truth (not only .env.example)
# Local Chromium: start=0 then SERP Next (#pnnext) until URL start matches SerpAPI (0,20,40,60…)
UDM1_CAPTURE_SYNC_PAGINATION=true
# Cloud browser: omit/false = direct goto full log URL. true = UI paging like local.
# UDM1_ZENROWS_SYNC_PAGINATION=false

# GMB – same values as parent config/gmb.js (from parent .env or these defaults)
GMB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMB_CLIENT_SECRET=your-google-client-secret
GMB_REDIRECT_URI=https://your-domain.com/oauth/google
GMB_REFRESH_TOKEN=your-google-refresh-token

# OpenAI API key for transcript analysis
OPENAI_API_KEY=your-openai-api-key

# -----------------------------------------------------------------------------
# AI keyword generation (automation / GMB keyword lists)
# AI stays ON: short "service + city/area" phrases only — not long random AI-heavy variants.
# KEYWORDS_AI_DISABLED=true  → skip OpenAI entirely (only deterministic buildKeywords from category+areas)
KEYWORDS_AI_DISABLED=false
KEYWORDS_AI_SERVICE_LOCATION_STRICT=true
# KEYWORDS_AI_LEGACY_PROMPT=true  → old looser prompt + higher temperature (not recommended)

# FREE CAPTCHA SOLVER (Get yours at https://wit.ai)
WIT_AI_TOKEN=VPFNORRRTAHRVRSPT2GLD7AU24PAG7NB

# Fathom API primary and backup keys
FATHOM_API_KEY=iBd_G_1wcNcFifU1019Hxw.7gxXDh2gDkJHTIsADc6otvfoWA_HhrBpJr1-zdfco6A
FATHOM_API_KEY_BACKUP=yZEBjejqs93ibjBdxKIl1Q.eM8OPv70cu5BPy1NunrVILWBnaFme863rlsRDr0Y0Xw

# -----------------------------------------------------------------------------
# Hourly pilot + unified rank tracking (server/rank_history/tracking/*.json)
#
# Manual first (recommended): keep ENABLE_HOURLY_PILOT_CRON=false → GMB tab → Search All
# → View Gallery → "Save to tracking history" (1st save direct; 2nd+ same GMB → confirm modal).
# Open /gmb-rank-history to compare after two snapshots. source=manual in JSON.
#
# Then enable cron: ENABLE_HOURLY_PILOT_CRON=true → same GMB (PILOT_GMB_NAME / optional ids).
# After each run: rank_history JSON + unified tracking/*.json append (source=cron) — same shape as
# manual “Save to tracking history”; no gallery button required. Needs ≥1 successful screenshot to append items.
# Fix EADDRINUSE :::5524: only one Node process may bind PORT; stop duplicate PM2/instance or change PORT.
#
# Optional selectors (production): PILOT_GMB_LOCATION_ID=…  PILOT_GMB_ACCOUNT_ID=…
# See .env.example for full pilot block. RANK_* URLs = screenshot + gallery links in JSON.
# -----------------------------------------------------------------------------
ENABLE_HOURLY_PILOT_CRON=false
PILOT_GMB_NAME=Elite Troop Pressure Washing & Painting
# First local run at 16:38 (4:38 PM); use PILOT_FIRST_RUN_HOUR=4 for 4:38 AM. Omit hour for "next :38 each hour".
PILOT_FIRST_RUN_HOUR=16
PILOT_FIRST_RUN_MINUTE=38
PILOT_INTERVAL_MINUTES=60
# Optional — same keys as .env.example; uncomment and set to pin one GMB for cron (recommended in prod):
# PILOT_GMB_LOCATION_ID=
# PILOT_GMB_ACCOUNT_ID=
# Local dev: JSON links + CORS for Client Hub Vite :8080. For deployed API, use synoventum URLs instead.
RANK_HISTORY_API_BASE_URL=https://google-search-ranking.synoventum.us.cc
RANK_HISTORY_FRONTEND_BASE_URL=https://google-search-ranking.synoventum.us.cc
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://formflow-buddy-admin.synoventum.us.cc,https://www.formflow-buddy-admin.synoventum.us.cc,https://clienthub.systemicdigital.io,https://www.clienthub.systemicdigital.io

# --- Client Hub: Web Design pipeline (Builder board) — stored in Mongo, same server ---
# POST /api/web-design-pipeline/progress/batch  JSON: { "clientIds": ["uuid", ...] }  (large boards; long GET ?clientIds=... causes HTTP 431)
# GET  /api/web-design-pipeline/progress?clientIds=...  (keep list short, under ~120 ids)
# PATCH /api/web-design-pipeline/progress/:clientId  (unlock + checkbox fields; no extra env here — uses MONGODB_URI)

    # Supabase (FormFlow Buddy CRM)
    SUPABASE_URL=https://zteyswygwmaqywzqcovx.supabase.co
    SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inp0ZXlzd3lnd21hcXl3enFjb3Z4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYzMDM5NDksImV4cCI6MjA5MTg3OTk0OX0.I2VtiAElMnsPPr_77tHyVjk3-oEkl2ZAkw4J01T53zU
    # Paying + GMB “Active” — client list from same API as Client Hub (233), not Supabase-only (RLS can hide rows).
    USE_FORMFLOW_CRM_CLIENTS=true
    FORMFLOW_CRM_API_BASE=https://click.acquisition-central.com
    # Same key as client-hub-admin VITE_FORMFLOW_CRM_API_KEY (required for CRM route auth)
    # FORMFLOW_CRM_API_KEY=
    SUPABASE_SYNC_REGION=es
    SUPABASE_SYNC_REQUIRE_GMB_ACTIVE=true
    # Optional: override path to Client Hub snapshot (default: ../formflow-buddy/client-hub-admin/public/auto-connected-gmb.json)
    # AUTO_CONNECTED_GMB_JSON_PATH=
    SUPABASE_SYNC_PAYING_PIPELINE_ONLY=true
    # Daily paying+GBP: Supabase sync then dashboard_snapshots.json (~03:00 IST = 21:30 UTC)
    ENABLE_PAYING_GBP_DASHBOARD_CRON=true
    DASHBOARD_CRON_UTC_HOUR=21
    DASHBOARD_CRON_UTC_MINUTE=30

    # Dashboard "Total GMB" = active-gmb `count` ∩ gmb_keyword_counts keywordsCount in this inclusive band (default 1–6)
DASHBOARD_QUALIFIED_KEYWORDS_MIN=1
# Optional upper cap for dashboard "qualified" pool (omit or comment for 1+ keywords only, no max)
# DASHBOARD_QUALIFIED_KEYWORDS_MAX=6

# Align gmb_keyword_counts.json to active-gmb before dashboard (~2:30 IST = 21:00 UTC; dashboard 21:30 UTC)
    ENABLE_KEYWORDS_ALIGN_CRON=true
    KEYWORDS_ALIGN_CRON_UTC_HOUR=21
    KEYWORDS_ALIGN_CRON_UTC_MINUTE=0
    # Optional: run align once on server boot (default false)
    # KEYWORDS_ALIGN_ON_STARTUP=true

    # Automation Trigger & Global Controls
    AUTO_SCHEDULE_ONBOARDING_RUN=true
    AUTO_SCHEDULE_TIME=2026-04-27T09:45:00.000Z
    STOP_ALL_AUTOMATION=false

# -----------------------------------------------------------------------------
# GMB auto-connect snapshot (GET /api/gmbautoconnect) — nightly rebuild ~03:30 IST (22:00 UTC default)
# -----------------------------------------------------------------------------
ENABLE_AUTOCONNECT_REBUILD_CRON=true
AUTOCONNECT_CRON_UTC_HOUR=22
AUTOCONNECT_CRON_UTC_MINUTE=0
AUTOCONNECT_CRM_REGION=es
# Output JSON (default: google-search-ranking/server/data/auto-connected-gmb.json)
# AUTO_CONNECTED_GMB_OUTPUT_PATH=
# Override read path for API + Supabase sync (optional; else server/data then Client Hub public)
# AUTO_CONNECTED_GMB_JSON_PATH=
AUTOCONNECT_MIRROR_TO_CLIENT_HUB_PUBLIC=true
AUTOCONNECT_REBUILD_ON_STARTUP=false

# -----------------------------------------------------------------------------
# MongoDB — ranking server (AutomationRun jobs, web-design pipeline, gallery).
# When MONGODB_URI is set here, it overrides repo root config/database.js (see src/db/mongo.js).
# Atlas: same user must have readWrite on MONGODB_DB_NAME (fixes "not allowed to do action [find] on [test.automationrunjobs]").
# Host must match Atlas → Connect (Compass shows cluster0.slkicii… — if URI uses a different subdomain, paste Atlas string).
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://terrencechungong_db_user:Chefor2004@cluster0.s1kicii.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=test
